          "region": "europe-west1"
        }
      },
      {
        "source": "/api/admin/orders",
        "function": {
          "functionId": "getAdminOrders",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/admin/complete",
        "function": {
